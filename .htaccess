# ============================================================
#  .htaccess — Configuración principal del proyecto
#  Grupo Ferretero Piedras
# ============================================================

# ── Archivo de inicio por defecto ──────────────────────────
DirectoryIndex index.html Home/Home.html

# ── Deshabilitar listado de directorios ────────────────────
Options -Indexes

# ── Proteger archivos sensibles ────────────────────────────
<FilesMatch "\.(env|log|sql|json|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Bloquear acceso directo a archivos de diagnóstico ──────
<FilesMatch "^(test_|debug_|diag_|fix_|migrate_|run_setup|alter_table|setup_|diagnostico)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Habilitar compresión GZIP para mejor rendimiento ───────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── Cabeceras de seguridad básicas ─────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ── Cache estática para assets ─────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
